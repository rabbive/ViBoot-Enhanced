{
	"manifest_version": 2,
	"name": "ViBoot Enhanced",
	"description": "Enhance your VTOP in one-click.",
	"version": "1.5",
	"author": "Arsh Saxena and Aishik Tokdar",
	"icons": {
		"16": "assets/icons/img_16.png",
		"48": "assets/icons/img_48.png",
		"128": "assets/icons/img_128.png"
	},
	"browser_specific_settings": {
		"gecko": {
			"id": "viboot-enhanced@vitrendz.com"
		}
	},
	"permissions": [
		"webRequest",
		"downloads",
		"storage",
		"tabs",
		"alarms",
		"notifications",
		"*://vtop.vit.ac.in/*",
		"*://vtopcc.vit.ac.in/vtop/*",
		"*://vtop.vitbhopal.ac.in/vtop/*"
	],
	"background": {
		"scripts": ["service_worker/background.js"],
		"persistent": true
	},
	"content_scripts": [
		{
			"matches": [
				"*://vtop.vit.ac.in/*",
				"*://vtopcc.vit.ac.in/vtop/*",
				"*://vtop.vitbhopal.ac.in/vtop/*"
			],
			"js": [
				"js/captcha/bitmaps.js",
				"js/captcha/captchaparser.js",
				"js/attendance.js",
				"js/course_page.js",
				"js/exam_schedule.js",
				"js/marks_page.js",
				"js/navbar.js",
				"js/navbarcc.js",
				"js/on_duty.js",
				"js/time_table.js"
			]
		}
	],
	"browser_action": {
		"default_icon": {
			"16": "assets/icons/img_16.png",
			"48": "assets/icons/img_48.png",
			"128": "assets/icons/img_128.png"
		},
		"default_popup": "html/popup.html",
		"default_title": "ViBoot Enhanced"
	}
}
